# =============================================================================
# kgaf3_chatbot — Docker environment template / 환경 변수 예시
# Copy & fill in:  cp .env.docker.example .env.docker   (never commit your .env.docker)
# 복사 후 작성:    cp .env.docker.example .env.docker   (실제 .env.docker 는 커밋 금지)
# NOTE: docker-compose.yml reads `.env.docker` (not `.env`). The installer
#       (install.sh / configure.md) generates this file for you automatically.
#
# Paths below are CONTAINER paths (volumes), not host paths.
# 아래 경로는 호스트 경로가 아니라 컨테이너 내부(볼륨) 경로입니다.
# =============================================================================

# ── App ─────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=5013
LOG_LEVEL=INFO
LOG_FORMAT=json                 # json | console (structlog, Zero-Script QA 호환)

# ── OpenRouter (LLM) ────────────────────────────────────────────────────────
# REQUIRED. Get a key at https://openrouter.ai/keys  (필수 — 발급 후 입력)
OPENROUTER_API_KEY=sk-or-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default model shown in the UI (user-selectable). 기본 모델 (UI 에서 변경 가능)
LLM_DEFAULT_MODEL=anthropic/claude-sonnet-4-6
# Allowed models for the UI dropdown (comma-separated). 허용 모델 목록 (콤마 구분)
LLM_ALLOWED_MODELS=anthropic/claude-sonnet-4-6,anthropic/claude-opus-4-7,openai/gpt-4o-mini,google/gemini-pro-1.5,meta-llama/llama-3.3-70b-instruct
# OpenRouter app metadata (optional). OpenRouter 앱 메타데이터 (선택)
OPENROUTER_APP_NAME=afmm_chat
OPENROUTER_HTTP_REFERER=http://localhost:5013

# ── MCP Endpoints (HTTP) ────────────────────────────────────────────────────
# EXTERNAL AF3 cofolding MCP — runs OUTSIDE this compose, on the Docker host.
# 외부 AF3 코폴딩 MCP — 본 compose 밖, Docker 호스트에서 구동.
AF3_MCP_URL=http://host.docker.internal:8002/mcp/
AF3_MCP_AUTH_TOKEN=
# Bundled smina-only MCP (service "smina-mcp", internal network).
# NOTE: env name kept as OPENMM_MCP_URL for code compatibility — it now points
#       at the bundled smina MCP, not OpenMM. (Lite 프로파일: 변수명은 호환 위해 유지)
# 번들된 smina 전용 MCP (서비스명 "smina-mcp", 내부 네트워크).
OPENMM_MCP_URL=http://smina-mcp:8001/mcp/
OPENMM_MCP_AUTH_TOKEN=

# ── Pipeline mode (Lite) ────────────────────────────────────────────────────
# FIXED for the Lite profile: OpenMM is NOT bundled. Keep this false.
# Lite 프로파일 고정값 — OpenMM 미포함. false 로 유지하세요.
USE_OPENMM=false
# smina --minimize scoring function. smina 스코어링 함수.
SMINA_SCORING=vinardo            # vinardo | vina

# ── GraphRAG (Neo4j knowledge graph, via bundled MCP over SSE) ───────────────
# ON BY DEFAULT — the knowledge graph is a first-class chat mode (🧬), not an
# add-on. A plain `docker compose up -d` starts ALL FOUR services (kgaf3-chat,
# smina-mcp, neo4j, graphrag-mcp). There is NO `graphrag` compose profile.
# 기본 활성 — 지식 그래프(🧬)는 부가 기능이 아니라 1급 채팅 모드입니다.
# `docker compose up -d` 하나로 네 서비스(kgaf3-chat, smina-mcp, neo4j,
# graphrag-mcp)가 모두 뜹니다. 별도 `graphrag` 프로파일은 없습니다.
#
# When true, kgaf3-chat connects to the self-contained GraphRAG Docker stack
# (yoonjuho94/graphrag-neo4j:1.0 + yoonjuho94/graphrag-mcp-server:1.1) which
# exposes an MCP SSE server. The KG (273,519 nodes / 1,493,463 relationships)
# is baked into the neo4j image and auto-loads on first boot (~1 min). The MCP
# server holds the Neo4j driver and the LLM key used by graphrag_query —
# kgaf3-chat only calls the MCP tools.
#
# Opt out (screening-only): set GRAPHRAG_ENABLED=false and start only the two
# core services, skipping the KG images:
#   docker compose up -d kgaf3-chat smina-mcp
# 스크리닝 전용으로 쓰려면 GRAPHRAG_ENABLED=false 로 두고 위 명령으로
# 두 서비스만 띄우면 KG 이미지를 내려받지 않습니다. (configure.md / docs/GRAPHRAG.md 참고)
GRAPHRAG_ENABLED=true
# MCP SSE endpoint. Compose 내부망 서비스명 기준 (호스트에서 직접 띄우면
# http://host.docker.internal:8893/sse 등으로 변경).
GRAPHRAG_MCP_URL=http://graphrag-mcp:8893/sse
# Bearer token — only if you put the MCP server behind auth (기본 빈 값).
GRAPHRAG_MCP_AUTH_TOKEN=
# Display/history label only — the real GraphRAG LLM model is set in the MCP
# server's own .env (OPENROUTER_MODEL). afmm_chat 은 이 값을 표시용으로만 사용.
GRAPHRAG_OPENROUTER_MODEL=anthropic/claude-opus-4-7

# ── Storage (container paths) ───────────────────────────────────────────────
# SQLite jobs DB. SQLite 작업 DB.
AFMM_DB_PATH=/data/afmm.db
# Compound library upload dir. 화합물 라이브러리 업로드 디렉토리.
AFMM_LIBRARY_DIR=/data/uploads
# REQUIRED. AF3 result import root — mount the AF3 output dir read-only here.
# 필수 — AF3 결과 임포트 루트. AF3 출력 디렉토리를 읽기 전용으로 마운트.
AF3_OUTPUT_ROOT=/data/af3_output
# Shared work volume ("afmm_work"), mounted in BOTH afmm-chat and smina-mcp.
# afmm-chat splits AF3 holo complex -> receptor.pdb/ligand.sdf written here;
# smina-mcp reads the exact same paths.
# 공유 작업 볼륨 ("afmm_work") — afmm-chat 와 smina-mcp 양쪽에 마운트.
OPENMM_WORK_ROOT=/data/work

# ── Auth (optional) ─────────────────────────────────────────────────────────
# Leave empty when running behind nginx BasicAuth / reverse proxy.
# nginx BasicAuth / 리버스 프록시 뒤에서는 비워둠.
AFMM_API_TOKEN=
